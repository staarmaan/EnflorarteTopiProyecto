@model Arreglo
@{
    Layout = null;
}

<div class="p-2">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-5">
                    @if (!string.IsNullOrWhiteSpace(Model.FotoRuta))
                    {
                        <img src="@Model.FotoRuta" class="w-100 rounded border detalle-arreglo-img" alt="@Model.Nombre" />
                    }
                    else
                    {
                        <div class="w-100 rounded border d-flex align-items-center justify-content-center text-muted detalle-arreglo-img">Sin imagen</div>
                    }
                </div>

                <div class="col-12 col-md-7">
                    <h4 class="card-title mb-2">@Model.Nombre</h4>
                    <p class="text-muted mb-3">@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción." : Model.Descripcion)</p>

                    <div class="small text-muted mb-1">Flores del arreglo:</div>
                    @if (Model.Flores.Count == 0)
                    {
                        <div class="text-muted">No hay flores registradas en este arreglo.</div>
                    }
                    else
                    {
                        <ul class="mb-3">
                            @foreach (var florArreglo in Model.Flores.OrderBy(f => f.Flor.Nombre))
                            {
                                <li>@florArreglo.Flor.Nombre x @florArreglo.Cantidad (@florArreglo.ColorSeleccionado)</li>
                            }
                        </ul>
                    }

                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <button type="button"
                                class="btn btn-outline-primary"
                                onclick="cargarModalCatalogo('@Url.Action("EditarArreglo", "ControladorCatalogo", new { id = Model.Id })', 'Editar Arreglo')">
                            Editar arreglo
                        </button>

                        @if (User.IsInRole("supervisor"))
                        {
                            <button type="button" class="btn btn-outline-danger" onclick="confirmarEliminarArreglo(@Model.Id)">Borrar arreglo</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("supervisor"))
{
    <form id="formEliminarArreglo" asp-action="EliminarArreglo" asp-controller="ControladorCatalogo" method="post" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" id="eliminarArregloId" name="id" />
        <input type="hidden" id="eliminarArregloContrasena" name="contrasenaSupervisor" />
    </form>
}

<style>
    .detalle-arreglo-img {
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background-color: #f8f9fa;
    }
</style>

<script>
    function confirmarEliminarArreglo(arregloId) {
        var confirmar = confirm('żSeguro que deseas borrar este arreglo? Esta acción no se puede deshacer.');
        if (!confirmar) {
            return;
        }

        var contrasena = prompt('Ingresa la contraseńa del supervisor para confirmar:');
        if (!contrasena) {
            return;
        }

        $('#eliminarArregloId').val(arregloId);
        $('#eliminarArregloContrasena').val(contrasena);
        $('#formEliminarArreglo').trigger('submit');
    }
</script>
