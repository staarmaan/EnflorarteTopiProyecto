@model EditarInventarioFlorDto
@{
    Layout = null;
}

<div class="p-2">
    <form asp-action="EditarInventarioFlor" asp-controller="ControladorCatalogo" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="FlorId" />

        <div class="card card-enflorarte h-100 shadow-sm">
            <div class="card-header text-center py-3">
                Editar Inventario
            </div>
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-4">
                        @if (!string.IsNullOrWhiteSpace(Model.FotoRutaFlor))
                        {
                            <img src="@Model.FotoRutaFlor" class="w-100 rounded border inventario-flor-img" alt="@Model.NombreFlor" />
                        }
                        else
                        {
                            <div class="w-100 rounded border d-flex align-items-center justify-content-center text-muted inventario-flor-img">Sin imagen</div>
                        }
                    </div>
                    <div class="col-12 col-md-8">
                        <h5 class="mb-1">@Model.NombreFlor</h5>
                        <p class="text-muted mb-0">@(string.IsNullOrWhiteSpace(Model.DescripcionFlor) ? "Sin descripción." : Model.DescripcionFlor)</p>
                    </div>
                </div>

                @if (Model.Colores.Count == 0)
                {
                    <div class="alert alert-warning mb-3">No hay colores para esta flor.</div>
                }
                else
                {
                    <div class="table-responsive border rounded mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Color</th>
                                    <th style="width:120px;">Actual</th>
                                    <th style="width:150px;">Agregar</th>
                                    <th style="width:150px;">Quitar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Colores.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            @Model.Colores[i].Color
                                            <input type="hidden" asp-for="Colores[i].InventarioId" />
                                            <input type="hidden" asp-for="Colores[i].Color" />
                                            <input type="hidden" asp-for="Colores[i].CantidadActual" />
                                        </td>
                                        <td>@Model.Colores[i].CantidadActual</td>
                                        <td>
                                            <input asp-for="Colores[i].AgregarCantidad" type="text" inputmode="numeric" maxlength="3" class="form-control form-control-sm input-cantidad-inventario" />
                                        </td>
                                        <td>
                                            <input asp-for="Colores[i].QuitarCantidad" type="text" inputmode="numeric" maxlength="3" class="form-control form-control-sm input-cantidad-inventario" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="border rounded p-3 bg-light-subtle">
                    <label asp-for="NuevoColor" class="form-label text-muted small text-uppercase fw-bold mb-1">Otro color</label>
                    <div class="input-group input-group-sm">
                        <input asp-for="NuevoColor" class="form-control" maxlength="50" placeholder="Ej. Amarillo" />
                        <button type="submit" class="btn btn-outline-primary" name="accion" value="agregar-color">Agregar color</button>
                    </div>
                    <span asp-validation-for="NuevoColor" class="text-danger small"></span>
                    <div class="form-text">Se agrega para esta flor con cantidad inicial 0.</div>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary px-4" name="accion" value="guardar">Guardar inventario</button>
        </div>
    </form>
</div>

<style>
    .inventario-flor-img {
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background-color: #f8f9fa;
    }
</style>

<script>
    $(document).on('input', '.input-cantidad-inventario', function () {
        var valor = ($(this).val() || '').toString();
        valor = valor.replace(/\D/g, '').slice(0, 3);
        $(this).val(valor);
    });
</script>
