@model Flor
@{
    Layout = null;
}

<div class="p-2">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-5">
                    @if (!string.IsNullOrWhiteSpace(Model.FotoRuta))
                    {
                        <img src="@Model.FotoRuta" class="w-100 rounded border detalle-flor-img" alt="@Model.Nombre" />
                    }
                    else
                    {
                        <div class="w-100 rounded border d-flex align-items-center justify-content-center text-muted detalle-flor-img">Sin imagen</div>
                    }
                </div>
                <div class="col-12 col-md-7">
                    <h4 class="card-title mb-2">@Model.Nombre</h4>
                    <p class="text-muted mb-3">@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción." : Model.Descripcion)</p>

                    <div class="small text-muted mb-1">Inventario por color:</div>
                    @if (Model.InventarioColores.Count == 0)
                    {
                        <div class="text-muted">No hay colores registrados para esta flor.</div>
                    }
                    else
                    {
                        <ul class="mb-3">
                            @foreach (var inventario in Model.InventarioColores.OrderBy(c => c.Color))
                            {
                                <li>@inventario.Color: @inventario.Cantidad</li>
                            }
                        </ul>
                    }

                    <button type="button"
                            class="btn btn-accion-redondo btn-editar-redondo"
                            onclick="cargarModalCatalogo('@Url.Action("EditarInventarioFlor", "ControladorCatalogo", new { id = Model.Id })', 'Editar Inventario')"
                            title="Editar inventario"
                            aria-label="Editar inventario">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M12 20h9" />
                            <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L8 18l-4 1 1-4 11.5-11.5z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .detalle-flor-img {
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background-color: #f8f9fa;
    }
</style>
