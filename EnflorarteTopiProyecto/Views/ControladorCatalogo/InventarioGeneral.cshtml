@model InventarioGeneralViewModel
@{
    Layout = null;
}

<div class="p-2">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 p-md-4">
            @if (Model.Filas.Count == 0)
            {
                <div class="alert alert-light border text-muted mb-0">No hay flores registradas para mostrar inventario.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width: 180px;">Flor</th>
                                @foreach (var color in Model.Colores)
                                {
                                    <th class="text-center" style="min-width: 110px;">@color</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fila in Model.Filas)
                            {
                                <tr>
                                    <td class="fw-semibold">@fila.FlorNombre</td>
                                    @foreach (var color in Model.Colores)
                                    {
                                        <td class="text-center">@fila.CantidadesPorColor[color]</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
