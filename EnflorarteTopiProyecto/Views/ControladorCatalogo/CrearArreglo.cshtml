@model ArregloDto
@{
    Layout = null;
}

<div class="p-2">
    <form asp-action="CrearArreglo" asp-controller="ControladorCatalogo" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="card card-enflorarte h-100 shadow-sm">
            <div class="card-header text-center py-3">
                Registrar Arreglo
            </div>
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label text-muted small text-uppercase fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FotoArchivo" class="form-label text-muted small text-uppercase fw-bold"></label>
                    <input asp-for="FotoArchivo" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="FotoArchivo" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label text-muted small text-uppercase fw-bold"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

                <div class="mb-1">
                    <label class="form-label text-muted small text-uppercase fw-bold">Flores del arreglo</label>
                </div>

                @if (Model.Flores.Count == 0)
                {
                    <div class="alert alert-warning mb-0">No hay flores registradas todavía. Primero agrega flores al catálogo.</div>
                }
                else
                {
                    <div class="row g-2 mb-3">
                        <div class="col-12 col-md-8">
                            <label for="selectFlorCatalogo" class="form-label text-muted small text-uppercase fw-bold mb-1">Lista de flores</label>
                            <select id="selectFlorCatalogo" class="form-select form-select-sm">
                                <option value="">Selecciona una flor...</option>
                                @foreach (var flor in Model.Flores.OrderBy(f => f.FlorNombre))
                                {
                                    <option value="@flor.FlorId" data-nombre="@flor.FlorNombre" data-colores="@string.Join("|", flor.ColoresDisponibles)">@flor.FlorNombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4 d-flex align-items-end">
                            <button type="button" id="btnAgregarFlorArreglo" class="btn btn-outline-secondary-flower btn-sm w-100">Agregar flor</button>
                        </div>
                    </div>

                    <div class="table-responsive tabla-enflorarte-wrap">
                        <table class="table table-sm table-hover align-middle mb-0 tabla-enflorarte-catalogo">
                            <thead>
                                <tr>
                                    <th>Flor</th>
                                    <th style="width: 140px;">Cantidad</th>
                                    <th style="width: 120px;">Color</th>
                                    <th style="width: 120px;" class="text-end pe-4">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyFloresSeleccionadas">
                                @{
                                    var seleccionadas = Model.Flores.Where(f => f.Seleccionada).ToList();
                                }
                                @for (int i = 0; i < seleccionadas.Count; i++)
                                {
                                    <tr data-flor-id="@seleccionadas[i].FlorId">
                                        <td>
                                            @seleccionadas[i].FlorNombre
                                            <input type="hidden" name="Flores[@i].FlorId" value="@seleccionadas[i].FlorId" />
                                            <input type="hidden" name="Flores[@i].FlorNombre" value="@seleccionadas[i].FlorNombre" />
                                            <input type="hidden" name="Flores[@i].Seleccionada" value="true" />
                                        </td>
                                        <td>
                                            <input name="Flores[@i].Cantidad" value="@seleccionadas[i].Cantidad" type="number" min="1" class="form-control form-control-sm" />
                                        </td>
                                        <td>
                                            <select name="Flores[@i].ColorSeleccionado" class="form-select form-select-sm">
                                                @foreach (var color in seleccionadas[i].ColoresDisponibles)
                                                {
                                                    <option value="@color" selected="@(string.Equals(color, seleccionadas[i].ColorSeleccionado, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@color</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="text-end pe-4">
                                            <button type="button" class="btn btn-accion-redondo btn-eliminar-redondo btn-eliminar-flor" title="Quitar flor" aria-label="Quitar flor">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                    <path d="M3 6h18" />
                                                    <path d="M8 6V4h8v2" />
                                                    <path d="M19 6l-1 14H6L5 6" />
                                                    <path d="M10 11v6" />
                                                    <path d="M14 11v6" />
                                                </svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div id="mensajeSinFloresSeleccionadas" class="text-muted small mt-2 @(seleccionadas.Count == 0 ? string.Empty : "d-none")">
                        Aún no agregas flores al arreglo.
                    </div>
                    <span asp-validation-for="Flores" class="text-danger small"></span>
                }
            </div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary px-4" @(Model.Flores.Count == 0 ? "disabled" : null)>Guardar Arreglo</button>
        </div>
    </form>
</div>

<script>
    function actualizarIndicesFloresSeleccionadas() {
        $('#tbodyFloresSeleccionadas tr').each(function (index) {
            $(this).find('input[name$=".FlorId"]').attr('name', 'Flores[' + index + '].FlorId');
            $(this).find('input[name$=".FlorNombre"]').attr('name', 'Flores[' + index + '].FlorNombre');
            $(this).find('input[name$=".Seleccionada"]').attr('name', 'Flores[' + index + '].Seleccionada');
            $(this).find('input[name$=".Cantidad"]').attr('name', 'Flores[' + index + '].Cantidad');
            $(this).find('select[name$=".ColorSeleccionado"]').attr('name', 'Flores[' + index + '].ColorSeleccionado');
        });
    }

    function actualizarMensajeSinFlores() {
        if ($('#tbodyFloresSeleccionadas tr').length === 0) {
            $('#mensajeSinFloresSeleccionadas').removeClass('d-none');
        } else {
            $('#mensajeSinFloresSeleccionadas').addClass('d-none');
        }
    }

    function obtenerNombreFlorSeleccionada() {
        var $option = $('#selectFlorCatalogo option:selected');
        if (!$option.val()) {
            return '';
        }

        return ($option.data('nombre') || $option.text() || '').toString();
    }

    function obtenerOpcionesColorHtml(florId, colorSeleccionado) {
        var $option = $('#selectFlorCatalogo option[value="' + florId + '"]');
        var rawColores = ($option.data('colores') || 'a elegir').toString();
        var colores = rawColores.split('|').filter(function (c) { return c && c.trim().length > 0; });

        if (colores.length === 0) {
            colores = ['a elegir'];
        }

        if (!colorSeleccionado) {
            colorSeleccionado = 'a elegir';
        }

        if (colores.findIndex(function (c) { return c.toLowerCase() === colorSeleccionado.toLowerCase(); }) < 0) {
            colores.unshift('a elegir');
        }

        var html = '';
        colores.forEach(function (color) {
            var selected = color.toLowerCase() === colorSeleccionado.toLowerCase() ? ' selected' : '';
            html += '<option value="' + color + '"' + selected + '>' + color + '</option>';
        });

        return html;
    }

    function agregarFlorSeleccionadaATabla() {
        var florId = ($('#selectFlorCatalogo').val() || '').toString();
        if (!florId) {
            return;
        }

        var nombre = obtenerNombreFlorSeleccionada();
        var $tbody = $('#tbodyFloresSeleccionadas');
        var $filaExistente = $tbody.find('tr[data-flor-id="' + florId + '"]');

        if ($filaExistente.length > 0) {
            var $inputCantidad = $filaExistente.find('input[name$=".Cantidad"]');
            var cantidadActual = parseInt($inputCantidad.val()) || 1;
            $inputCantidad.val(cantidadActual + 1);
            return;
        }

        var nuevoIndex = $tbody.find('tr').length;
        var fila = '' +
            '<tr data-flor-id="' + florId + '">' +
            '  <td>' +
            '    ' + nombre +
            '    <input type="hidden" name="Flores[' + nuevoIndex + '].FlorId" value="' + florId + '" />' +
            '    <input type="hidden" name="Flores[' + nuevoIndex + '].FlorNombre" value="' + nombre + '" />' +
            '    <input type="hidden" name="Flores[' + nuevoIndex + '].Seleccionada" value="true" />' +
            '  </td>' +
            '  <td><input name="Flores[' + nuevoIndex + '].Cantidad" type="number" min="1" value="1" class="form-control form-control-sm" /></td>' +
            '  <td><select name="Flores[' + nuevoIndex + '].ColorSeleccionado" class="form-select form-select-sm">' + obtenerOpcionesColorHtml(florId, 'a elegir') + '</select></td>' +
            '  <td class="text-end"><button type="button" class="btn btn-accion-redondo btn-eliminar-redondo btn-eliminar-flor" title="Quitar flor" aria-label="Quitar flor"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg></button></td>' +
            '</tr>';

        $tbody.append(fila);
        actualizarIndicesFloresSeleccionadas();
        actualizarMensajeSinFlores();
    }

    $('#btnAgregarFlorArreglo').on('click', agregarFlorSeleccionadaATabla);

    $('#selectFlorCatalogo').on('keydown', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            agregarFlorSeleccionadaATabla();
        }
    });

    $(document).on('click', '#tbodyFloresSeleccionadas .btn-eliminar-flor', function () {
        var $fila = $(this).closest('tr');
        var nombreFlor = ($fila.find('input[name$=".FlorNombre"]').val() || '').toString();
        var confirmar = confirm('żEliminar "' + nombreFlor + '" del arreglo?');
        if (!confirmar) {
            return;
        }

        $fila.remove();
        actualizarIndicesFloresSeleccionadas();
        actualizarMensajeSinFlores();
    });

    actualizarIndicesFloresSeleccionadas();
    actualizarMensajeSinFlores();
</script>
