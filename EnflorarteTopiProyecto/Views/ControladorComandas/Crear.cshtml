@model ComandaDto

<h1 class="text-center mb=3">Nueva Comanda</h1>

<form asp-action="Crear" asp-controller="ControladorComandas" method="post">
    @Html.AntiForgeryToken()
    @* en partial name, Reutilizamos el formulario de comanda (_FormularioComanda.cshtml) para la creacion. *@
    @* en view-data, le indicamos al formulario reutilizado que estamos creando. *@
    <partial name="~/Views/Shared/_FormularioComanda.cshtml"
             model="Model"
             view-data='new ViewDataDictionary(ViewData) { { "EsEdicion", false } }' />
    <button type="submit" class="btn btn-primary me-2">Confirmar</button>
    <a class="btn btn-outline-primary" asp-controller="ControladorComandas" asp-action="Index" role="button">Cancelar</a>
</form>
