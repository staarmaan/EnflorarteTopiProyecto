@model IEnumerable<EnflorarteTopiProyecto.Models.Usuario>
@{
    ViewData["Title"] = "Bienvenido";
    ViewData["OcultarNav"] = true; // Esto activa el ocultamiento del men·
}

<div class="container d-flex flex-column justify-content-center align-items-center min-vh-100 py-5">

    <div class="text-center mb-5">
        <img src="~/images/image_b087d3.png"
             alt="Logo Enflorarte"
             class="img-fluid mb-3"
             style="max-height: 200px; filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.1));">

        <p class="lead text-muted">Selecciona tu usuario para comenzar el dĒa.</p>
    </div>

    <div class="card card-enflorarte shadow-lg border-0" style="width: 100%; max-width: 500px;">
        <div class="card-header text-center py-3 bg-white border-bottom-0">
            <span class="text-uppercase small fw-bold text-muted" style="letter-spacing: 2px;">Usuarios Disponibles</span>
        </div>

        <div class="list-group list-group-flush">
    @foreach (var u in Model)
    {
                if (u.Activo)
                {
                    <button type="button"
                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 px-4 border-bottom-0"
                            onclick="abrirLogin('@u.Id', '@u.Nombre')"
                            style="transition: background 0.3s;">

                        <div class="d-flex align-items-center">
                            <div class="rounded-circle me-3 d-flex align-items-center justify-content-center text-white fw-bold shadow-sm"
                                 style="width: 45px; height: 45px; background-color: var(--color-secundario); font-size: 1.2rem;">
                                @u.Nombre.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold" style="color: var(--color-texto-oscuro);">@u.Nombre</h6>
                                <small class="text-muted text-capitalize">@u.Rol</small>
                            </div>
                        </div>

                        <span class="text-muted"><i class="bi bi-chevron-right"></i></span>
                    </button>
                }
            }
        </div>

        <div class="card-footer text-center bg-light py-3 border-top-0">
            <small class="text-muted">┐No encuentras tu usuario? Contacta al supervisor.</small>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLogin" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow" style="border-radius: 15px; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <partial name="~/Views/Shared/_FormularioSesion.cshtml" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirLogin(id, nombre) {
            document.getElementById('lblNombreUsuario').textContent = nombre;
            document.getElementById('inputUsuarioId').value = id;
            var myModal = new bootstrap.Modal(document.getElementById('modalLogin'));
            myModal.show();
        }
    </script>
    }
    </tbody>
</table>