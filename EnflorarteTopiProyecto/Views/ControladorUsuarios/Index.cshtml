@model List<Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 m-0">Lista de Usuarios</h1>
        <a href="javascript:void(0);" onclick="cargarModal('@Url.Action("Crear", "ControladorUsuarios")', 'Nuevo Usuario')" class="btn btn-primary">
            + Nuevo Usuario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-enflorarte table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Nombre</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-group-divider">
                        @foreach (var usuario in Model)
                        {
                            string badgeClass = usuario.Activo ? "bg-success" : "bg-secondary";
                            string activoStr = usuario.Activo ? "Activo" : "Inactivo";

                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@usuario.Id</td>
                                <td class="fw-bold">@usuario.Nombre</td>
                                <td class="text-capitalize">@usuario.Rol</td>
                                <td><span class="badge @badgeClass rounded-pill fw-normal">@activoStr</span></td>
                                <td class="text-end pe-4">
                                    <button onclick="cargarModal('@Url.Action("Editar", "ControladorUsuarios", new { id = usuario.Id })', 'Editar Usuario')"
                                            class="btn btn-outline-primary btn-sm me-1">
                                        Editar
                                    </button>

                                    @*
                                    <a class="btn btn-outline-danger btn-sm" asp-controller="ControladorUsuarios" asp-action="Eliminar" asp-route-id="@usuario.Id">
                                        Eliminar
                                    </a>
                                    *@
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border: none; border-radius: 10px; overflow: hidden;">
            <div class="modal-header" style="background-color: var(--color-primario); color: white;">
                <h5 class="modal-title" id="modalTitulo" style="font-family: var(--fuente-serif-elegante);">Título</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="contenidoModal">
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Función para abrir el modal y cargar contenido
        function cargarModal(url, titulo) {
            // 1. Cambiar el título
            $("#modalTitulo").text(titulo);

            // 2. Mostrar spinner de carga mientras esperamos
            $("#contenidoModal").html('<div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>');

            // 3. Abrir el modal
            var myModal = new bootstrap.Modal(document.getElementById('modalUsuario'));
            myModal.show();

            // 4. Petición AJAX para traer el formulario (Crear o Editar)
            $.get(url, function(data) {
                $("#contenidoModal").html(data);
            });
        }

        // Manejo inteligente del envío del formulario (AJAX)
        // Esto evita que si hay un error de validación, se recargue la página en blanco
        $(document).on('submit', '#contenidoModal form', function(e) {
            e.preventDefault(); // Evitamos el submit normal
            var form = $(this);

            $.post(form.attr('action'), form.serialize(), function(response) {
                // Truco: Si la respuesta contiene "<!DOCTYPE html>", significa que el servidor
                // redireccionó al Index (éxito), así que recargamos la página.
                // Si no, es que devolvió el formulario con errores de validación.
                if (response.indexOf('<!DOCTYPE html>') > -1) {
                    location.reload();
                } else {
                    $("#contenidoModal").html(response); // Mostramos los errores en el modal
                }
            });
        });
    </script>
}