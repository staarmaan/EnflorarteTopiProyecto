@model UsuarioDto
@{
    var esEdicion = (ViewData["EsEdicion"] as bool?) ?? (Model != null && Model.Id > 0);
}

<div class="card card-enflorarte h-100 shadow-sm">
    <div class="card-header text-center py-3">
        @(esEdicion ? "Actualizar Datos" : "Registrar Nuevo Usuario")
    </div>
    <div class="card-body p-4">

        <div class="mb-4">
            <label class="form-label text-muted small text-uppercase fw-bold">Nombre completo</label>
            <input class="form-control form-control-lg" asp-for="Nombre" placeholder="Ej. Juan Pérez" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label text-muted small text-uppercase fw-bold">Rol asignado</label>
            <select class="form-select form-select-lg" asp-for="Rol">
                <option value="" selected hidden>Selecciona un rol...</option>
                <option value="supervisor">Supervisor</option>
                <option value="ventas">Vendedor</option>
                <option value="florista">Florista</option>
                <option value="repartidor">Repartidor</option>
            </select>
            <span asp-validation-for="Rol" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label text-muted small text-uppercase fw-bold">
                @(esEdicion ? "Nueva Contraseña" : "Contraseña")
            </label>
            <input class="form-control" type="password" asp-for="Contrasena"
                   autocomplete="@(esEdicion ? "current-password" : "new-password")"
                   placeholder="******" />
            <span asp-validation-for="Contrasena" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label text-muted small text-uppercase fw-bold">Confirmar Contraseña</label>
            <input class="form-control" type="password" asp-for="ConfirmarContrasena"
                   autocomplete="@(esEdicion ? "current-password" : "new-password")"
                   placeholder="******" />
            <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
        </div>
    </div>
</div>