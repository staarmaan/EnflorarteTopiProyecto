@{
    var message = TempData["Toast.Message"] as string;
    var type = TempData["Toast.Type"] as string ?? "info"; // success | info | warning | danger
    var undoAction = TempData["Toast.UndoAction"] as string;
    var undoText = TempData["Toast.UndoText"] as string ?? "Deshacer";
    var bgClass = type switch
    {
        "success" => "bg-success text-white",
        "info" => "bg-info text-dark",
        "warning" => "bg-warning text-dark",
        "danger" => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1060;">
        <div class="toast align-items-center show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header @bgClass">
                <strong class="me-auto">Notificación</strong>
                <small>Ahora</small>
                <button type="button" class="btn-close btn-close-white ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                <span>@message</span>

                @if (!string.IsNullOrWhiteSpace(undoAction))
                {
                    <form asp-action="DeshacerEliminacion" asp-controller="ControladorUsuarios" method="post" class="d-inline ms-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link p-0 align-baseline">@undoText</button>
                    </form>
                }
            </div>
        </div>
    </div>
}