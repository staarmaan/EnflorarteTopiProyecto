@model ComandaDto
@{
    var esEdicion = (ViewData["EsEdicion"] as bool?) ?? (Model != null && Model.Id > 0);
}

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

@* Este formulario se reutiliza para la creacion y eidicion de comandas. *@


<div class="card h-100">
    <div class="card-header">
        @(esEdicion ? "Actualiza los datos de la comanda" : "Ingrese los datos de la comanda")
    </div>
    <div class="card-body">
        <!-- Usuarios -->
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Usuario creador</label>
            <div class="col-sm-8">
                <select asp-for="UsuarioId" class="form-select" asp-items="ViewBag.ListaUsuarios">
                    <option value="">Selecciona un usuario</option>
                </select>
                <span asp-validation-for="UsuarioId" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Repartidor (opcional)</label>
            <div class="col-sm-8">
                <select asp-for="RepartidorId" class="form-select" asp-items="ViewBag.ListaRepartidores">
                    <option value="">Selecciona un repartidor</option>
                </select>
                <span asp-validation-for="RepartidorId" class="text-danger"></span>
            </div>
        </div>

        <!-- Cliente y entrega -->
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Nombre del cliente</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="ClienteNombre" />
                <span asp-validation-for="ClienteNombre" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Teléfono del cliente</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="ClienteTelefono" />
                <span asp-validation-for="ClienteTelefono" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Tipo de entrega</label>
            <div class="col-sm-8">
                <select id="selectTipoEntrega" class="form-select" asp-for="TipoEntrega">
                    <option value="" selected hidden>Selecciona un tipo</option>
                    <option value="envio">Envío</option>
                    <option value="recoger">Recoger</option>
                    <!-- <option value="otro">Otro</option> -->
                </select>
                <span asp-validation-for="TipoEntrega" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3" id="divDireccionEntrega">
            <label class="col-sm-4 col-form-label">Dirección de entrega</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="DireccionEntrega" />
                <span asp-validation-for="DireccionEntrega" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Fecha de entrega</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="FechaEntrega" type="date" />
                <span asp-validation-for="FechaEntrega" class="text-danger"></span>
            </div>
        </div>

        @* Seleccionar hora con un panelito *@
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Hora de entrega</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="HoraEntrega" type="time" />
                <span asp-validation-for="HoraEntrega" class="text-danger"></span>
            </div>
        </div>

        @* Ingresar la hora manalmente (comentado, porque me parece mas intuitivo la forma anterior, aunque no funcione bien con mi navegador, que es Opera)
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Hora de entrega</label>
            <div class="col-sm-8">
                <!-- Controles personalizados para permitir AM/PM -->
                <div class="input-group">
                    <input id="horaEntregaHora" class="form-control" type="number" min="1" max="12" placeholder="hh" />
                    <span class="input-group-text">:</span>
                    <input id="horaEntregaMinuto" class="form-control" type="number" min="0" max="59" placeholder="mm" />
                    <select id="horaEntregaMeridiano" class="form-select" style="max-width: 7rem;">
                        <option value="AM">AM</option>
                        <option value="PM">PM</option>
                    </select>
                </div>
                <!-- Campo oculto enlazado al modelo en formato 24h HH:mm -->
                <input id="horaEntregaHidden" class="form-control" asp-for="HoraEntrega" type="hidden" />
                <span asp-validation-for="HoraEntrega" class="text-danger"></span>
                <script>
                    (function () {
                        function pad(n) { return n.toString().padStart(2, '0'); }
                        function to24h(hour12, meridian) {
                            var h = parseInt(hour12, 10);
                            if (isNaN(h)) return null;
                            if (meridian === 'AM') {
                                return h === 12 ? 0 : h;
                            } else {
                                return h === 12 ? 12 : h + 12;
                            }
                        }

                        var hInput = document.getElementById('horaEntregaHora');
                        var mInput = document.getElementById('horaEntregaMinuto');
                        var meridianSel = document.getElementById('horaEntregaMeridiano');
                        var hidden = document.getElementById('horaEntregaHidden');

                        function updateHidden() {
                            var hour12 = hInput.value;
                            var minute = mInput.value;
                            var mer = meridianSel.value;
                            var h24 = to24h(hour12, mer);
                            var m = parseInt(minute, 10);
                            if (h24 == null || isNaN(m)) return; // espera valores válidos
                            hidden.value = pad(h24) + ':' + pad(m);
                        }

                        hInput.addEventListener('input', updateHidden);
                        mInput.addEventListener('input', updateHidden);
                        meridianSel.addEventListener('change', updateHidden);

                        // Inicializa controles desde el valor actual del modelo si existe
                        try {
                            if (hidden.value) {
                                var raw = hidden.value.trim();
                                // acepta HH:mm o HH:mm:ss
                                var parts = raw.split(':');
                                if (parts.length >= 2) {
                                    var h = parseInt(parts[0], 10);
                                    var mm = parseInt(parts[1], 10);
                                    if (!isNaN(h) && !isNaN(mm)) {
                                        var mer = h >= 12 ? 'PM' : 'AM';
                                        var hour12 = (h % 12) === 0 ? 12 : (h % 12);
                                        hInput.value = pad(hour12);
                                        mInput.value = pad(mm);
                                        meridianSel.value = mer;
                                    }
                                }
                            }
                            // Asegura que el campo oculto esté sincronizado al cargar
                            updateHidden();
                        } catch (e) { /* noop */ }
                    })();
                </script>
            </div>
        </div>
        *@

        <!-- Arreglo -->
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Nombre del arreglo</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="NombreArreglo" />
                <span asp-validation-for="NombreArreglo" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Precio del arreglo</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="PrecioArreglo" type="number" step="0.01" min="0" />
                <span asp-validation-for="PrecioArreglo" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Pago de envío</label>
            <div class="col-sm-8">
                <input class="form-control" asp-for="PagoEnvio" type="number" step="0.01" min="0" />
                <span asp-validation-for="PagoEnvio" class="text-danger"></span>
            </div>
        </div>

        

        <!-- Carga de imagen del arreglo -->
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Foto del arreglo (archivo)</label>
            <div class="col-sm-8">
                <input id="fotoArregloInput" class="form-control" asp-for="FotoArregloArchivo" type="file" accept="image/*" />
                <span asp-validation-for="FotoArregloArchivo" class="text-danger"></span>

                <!-- Contenedor de vista previa: se muestra si hay ruta existente o si se selecciona un archivo -->
                <div id="fotoArregloPreviewContainer" class="mt-2" style="display:@(string.IsNullOrWhiteSpace(Model?.FotoArregloRuta) ? "none" : "block");">
                    <img id="fotoArregloPreview" src="@(string.IsNullOrWhiteSpace(Model?.FotoArregloRuta) ? "" : Model.FotoArregloRuta)" alt="Foto arreglo" class="img-thumbnail" style="max-height: 200px;" />
                </div>

                <!-- Control para marcar eliminación de foto existente o seleccionada (creación y edición) -->
                <input type="hidden" asp-for="EliminarFoto" />
                <button type="button" id="btnEliminarFoto" class="btn btn-outline-danger btn-sm mt-2">Eliminar imagen</button>

                <script>
                    (function () {
                        var input = document.getElementById('fotoArregloInput');
                        var previewImg = document.getElementById('fotoArregloPreview');
                        var previewContainer = document.getElementById('fotoArregloPreviewContainer');
                        var btnEliminar = document.getElementById('btnEliminarFoto');
                        var eliminarFotoField = document.getElementById('EliminarFoto');

                        function clearPreview() {
                            if (previewImg) {
                                previewImg.src = '';
                            }
                            if (previewContainer) {
                                previewContainer.style.display = 'none';
                            }
                        }

                        function showPreview(url) {
                            if (!previewImg || !previewContainer) return;
                            previewImg.src = url;
                            previewContainer.style.display = 'block';
                        }

                        input.addEventListener('change', function (e) {
                            var file = e.target.files && e.target.files[0];
                            if (!file) {
                                // Si no hay archivo, intenta mantener la ruta existente (edición),
                                // o esconder en creación
                                var existingSrc = previewImg && previewImg.getAttribute('src');
                                if (existingSrc) {
                                    previewContainer.style.display = 'block';
                                } else {
                                    clearPreview();
                                }
                                return;
                            }

                            if (!file.type || file.type.indexOf('image/') !== 0) {
                                // No es imagen: limpiar
                                clearPreview();
                                return;
                            }

                            // Crear objeto URL temporal para vista previa
                            var url = URL.createObjectURL(file);
                            showPreview(url);

                            // Liberar el objeto URL cuando ya no se necesite (por cambio o submit)
                            input.addEventListener('blur', function () {
                                try { URL.revokeObjectURL(url); } catch (_) { /* noop */ }
                            }, { once: true });
                        });

                        if (btnEliminar) {
                            btnEliminar.addEventListener('click', function () {
                                // Marcar campo para eliminar en el modelo y limpiar vista previa
                                if (eliminarFotoField) eliminarFotoField.value = 'true';
                                clearPreview();
                                // También limpiar cualquier archivo seleccionado
                                if (input) input.value = '';
                            });
                        }
                    })();
                </script>
            </div>
        </div>

        <!-- Anticipo -->
        <div class="row mb-3">
            <label class="col-sm-4 col-form-label">Tipo de anticipo</label>
            <div class="col-sm-8">
                <select id="selectTipoAnticipo" class="form-select" asp-for="AnticipoTipo">
                    <option value="" selected hidden>Selecciona un tipo</option>
                    <option value="porcentaje">Porcentaje</option>
                    <option value="minimo">Mínimo</option>
                    <option value="manual">Manual</option>
                </select>
                <span asp-validation-for="AnticipoTipo" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <label id="labelAnticipoValor" class="col-sm-4 col-form-label">Anticipo total</label>
            <div class="col-sm-8">
                <input id="inputAnticipoValor" class="form-control" asp-for="AnticipoPagoTotal" type="number" step="0.01" min="0" />
                <span asp-validation-for="AnticipoPagoTotal" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>
